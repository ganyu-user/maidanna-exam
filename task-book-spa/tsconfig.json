{
  "compilerOptions": {
    "target": "ES5",
    "module": "none",
    "lib": ["ES2015", "DOM"],
    "outFile": "./dist/app.js",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
